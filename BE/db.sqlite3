INSERT INTO `sach` VALUES (1,'Kamienie na szaniec','Aleksander Kamiński','Văn học','https://example.com/b1.jpg','Câu chuyện cảm động về lòng dũng cảm thời kháng chiến Ba Lan.',4.8,150,'2026-03-24 16:09:14'),(2,'Mắt Biếc','Nguyễn Nhật Ánh','Văn học','https://example.com/b2.jpg','Tình yêu đơn phương đầy day dứt tại làng Đo Đo.',4.9,320,'2026-03-24 16:09:14'),(3,'Clean Code','Robert C. Martin','Công nghệ','https://example.com/b3.jpg','Kinh điển về lập trình sạch và tư duy hệ thống.',4.7,210,'2026-03-24 16:09:14'),(4,'Nhà Giả Kim','Paulo Coelho','Kỹ năng / Triết học','https://example.com/b4.jpg','Hành trình đi tìm sứ mệnh cuộc đời đầy triết lý.',4.5,500,'2026-03-24 16:09:14'),(5,'Sapiens','Yuval Noah Harari','Khoa học','https://example.com/b5.jpg','Lược sử về sự tiến hóa của loài người.',4.6,450,'2026-03-24 16:09:14'),(6,'Đắc Nhân Tâm','Dale Carnegie','Kỹ năng / Triết học','https://example.com/b6.jpg','Nghệ thuật giao tiếp và thu phục lòng người.',4.4,600,'2026-03-24 16:09:14'),(7,'Tôi Thấy Hoa Vàng Trên Cỏ Xanh','Nguyễn Nhật Ánh','Văn học','https://example.com/b7.jpg','Ký ức tuổi thơ nghèo khó nhưng đầy tình thân.',4.8,280,'2026-03-24 16:09:14'),(8,'Dế Mèn Phiêu Lưu Ký','Tô Hoài','Văn học','https://example.com/b8.jpg','Bài học về sự trưởng thành qua lăng kính loài vật.',4.9,150,'2026-03-24 16:09:14'),(9,'Số Đỏ','Vũ Trọng Phụng','Văn học','https://example.com/b9.jpg','Bản cáo trạng đanh thép về xã hội thực dân nửa phong kiến.',4.7,120,'2026-03-24 16:09:14'),(10,'Don\'t Make Me Think','Steve Krug','Công nghệ','https://example.com/b10.jpg','Nguyên lý cơ bản về trải nghiệm người dùng web.',4.6,90,'2026-03-24 16:09:14'),(11,'Bắt Trẻ Đồng Xanh','J.D. Salinger','Văn học','https://example.com/b11.jpg','Nỗi nổi loạn của tuổi trẻ trong xã hội hiện đại.',4.2,340,'2026-03-24 16:09:14'),(12,'Harry Potter 1','J.K. Rowling','Văn học','https://example.com/b12.jpg','Thế giới phù thủy đầy màu sắc và hấp dẫn.',4.9,1000,'2026-03-24 16:09:14'),(13,'Tư Duy Nhanh Và Chậm','Daniel Kahneman','Khoa học','https://example.com/b13.jpg','Khám phá hai hệ thống tư duy của não bộ.',4.5,200,'2026-03-24 16:09:14'),(14,'Dấu Chân Trên Cát','Nguyên Phong','Kỹ năng / Triết học','https://example.com/b14.jpg','Hành trình tâm linh về Ai Cập cổ đại.',4.7,180,'2026-03-24 16:09:14'),(15,'Lược Sử Thời Gian','Stephen Hawking','Khoa học','https://example.com/b15.jpg','Các khái niệm vật lý vũ trụ được giải thích đơn giản.',4.6,220,'2026-03-24 16:09:14'),(16,'Hành Trình Về Phương Đông','Baird T. Spalding','Kỹ năng / Triết học','https://example.com/b16.jpg','Khám phá các chân lý triết học Ấn Độ.',4.8,160,'2026-03-24 16:09:14'),(17,'JavaScript: The Good Parts','Douglas Crockford','Công nghệ','https://example.com/b17.jpg','Những tinh hoa và cạm bẫy trong ngôn ngữ JS.',4.3,80,'2026-03-24 16:09:14'),(18,'Thiên Tài Bên Trái, Kẻ Điên Bên Phải','Cao Minh','Kỹ năng / Triết học','https://example.com/b18.jpg','Góc nhìn khác biệt của những bệnh nhân tâm thần.',4.4,250,'2026-03-24 16:09:14'),(19,'Đường Xưa Mây Trắng','Thích Nhất Hạnh','Văn học','https://example.com/b19.jpg','Cuộc đời của Đức Phật qua ngòi bút thoát tục.',4.9,190,'2026-03-24 16:09:14'),(20,'Suối Nguồn','Ayn Rand','Kỹ năng / Triết học','https://example.com/b20.jpg','Tuyên ngôn về chủ nghĩa cá nhân và sự sáng tạo.',4.5,310,'2026-03-24 16:09:14');
